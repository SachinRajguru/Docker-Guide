# --------------------------------------
# Root-level .gitignore for Docker-based multi-service architecture
# --------------------------------------

# =========================
# Node.js (all services)
# =========================
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Environment files (never commit secrets)
# =========================
.env
.env.*
*.env
!.env.example

# =========================
# Docker data (runtime only)
# =========================
**/data/
**/db/
**/volumes/

# Docker build / local overrides
.docker-buildx/
Dockerfile.*.local
docker-compose.override.yml

# =========================
# Logs
# =========================
logs/
*.log

# =========================
# Temporary / Cache
# =========================
tmp/
temp/
.cache/
.tmp/

# =========================
# Build output
# =========================
dist/
build/
coverage/

# =========================
# OS-specific files
# =========================
.DS_Store
Thumbs.db
Desktop.ini

# =========================
# Editor / IDE
# =========================
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# =========================
# Process / runtime files
# =========================
*.pid
*.seed
*.pid.lock

# =========================
# Archives / exports
# =========================
*.zip
*.tar
*.tar.gz
*.gz
*.pdf

# =========================
# Optional: Docker images / exports
# =========================
*.img
*.iso